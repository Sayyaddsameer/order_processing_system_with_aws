# ============================================================
# Environment Variables — Copy to .env before running locally
#   cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# AWS / LocalStack
# ------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ACCOUNT_ID=000000000000
AWS_ENDPOINT_URL=http://localstack:4566

# ------------------------------------------------------------
# LocalStack Configuration
# ------------------------------------------------------------
LOCALSTACK_HOST=localstack
LOCALSTACK_PORT=4566
LOCALSTACK_DEBUG=0

# ------------------------------------------------------------
# Database (PostgreSQL / RDS)
# ------------------------------------------------------------
DB_HOST=postgres
DB_PORT=5432
DB_NAME=orders_db
DB_USER=orders_user
DB_PASSWORD=orders_password

# ------------------------------------------------------------
# SQS
# ------------------------------------------------------------
SQS_QUEUE_NAME=OrderProcessingQueue
SQS_DLQ_NAME=OrderProcessingDLQ
SQS_QUEUE_URL=http://localstack:4566/000000000000/OrderProcessingQueue
SQS_DLQ_RETENTION=1209600
SQS_QUEUE_VISIBILITY=60
SQS_QUEUE_RETENTION=86400
SQS_MAX_RECEIVE=3
SQS_BATCH_SIZE=5

# ------------------------------------------------------------
# SNS
# ------------------------------------------------------------
SNS_TOPIC_NAME=OrderStatusNotifications
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:000000000000:OrderStatusNotifications

# ------------------------------------------------------------
# Lambda
# ------------------------------------------------------------
LAMBDA_RUNTIME=python3.11
LAMBDA_TIMEOUT=30
LAMBDA_MEMORY=256

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
LOG_LEVEL=INFO
PROCESSING_SUCCESS_RATE=0.85
API_STAGE_NAME=local
